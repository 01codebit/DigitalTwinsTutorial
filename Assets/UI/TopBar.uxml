<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement name="TitleBar" style="flex-grow: 0; flex-direction: row; height: 140px; justify-content: space-between; background-color: rgb(0, 0, 0);">
        <ui:VisualElement name="SiteLabel" style="flex-grow: 0; background-color: rgb(59, 59, 59); background-image: url(&quot;project://database/Assets/UI/Sprites/UnityIndustry.png?fileID=2800000&amp;guid=7cf72d6f7c78f4040b09f44f691d0390&amp;type=3#UnityIndustry&quot;); flex-shrink: 0; width: 600px;"/>
        <ui:VisualElement name="ProfileGroup" style="flex-grow: 0; background-color: rgb(0, 0, 0); flex-direction: row; flex-shrink: 0; align-items: center;">
            <ui:Button text="&#10;" name="AppOptionsButton" style="width: 120px; height: 120px; background-color: rgb(89, 89, 89); background-image: url(&quot;project://database/Assets/UI/Sprites/ProfileIcon.png?fileID=21300000&amp;guid=30ee825d1114b8d48bd45490cb2ac8e8&amp;type=3#ProfileIcon&quot;); border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0; border-top-left-radius: 16px; border-top-right-radius: 16px; border-bottom-right-radius: 16px; border-bottom-left-radius: 16px;"/>
            <ui:Button text="&#10;" name="ProfileButton" style="width: 120px; height: 120px; border-top-left-radius: 16px; border-top-right-radius: 16px; border-bottom-right-radius: 16px; border-bottom-left-radius: 16px; border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0; background-color: rgb(89, 89, 89); background-image: url(&quot;project://database/Assets/UI/Sprites/KabobIcon.png?fileID=21300000&amp;guid=56261beca1c48d2498be5bcc436a7c76&amp;type=3#KabobIcon&quot;);"/>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
